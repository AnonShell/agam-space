{
  "name": "api-server",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "rimraf tsconfig.tsbuildinfo && nest start --watch",
    "start": "nest start",
    "build": "rimraf dist && nest build && mkdir -p dist/migrations && cp -r ./migrations dist/migrations",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --config test/integration/jest-integration.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "lint": "eslint . --ext .ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@agam-space/core": "workspace:*",
    "@agam-space/shared-types": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/middie": "^9.1.0",
    "@fastify/static": "^8.3.0",
    "@napi-rs/blake-hash": "^1.3.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/platform-fastify": "^11.1.11",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.4",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@simplewebauthn/server": "^13.2.2",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.6.2",
    "helmet": "^8.1.0",
    "nestjs-zod": "^4.3.1",
    "pg": "^8.16.3",
    "postgres": "^3.4.8",
    "sirv": "^3.0.2",
    "ulid": "^3.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.11",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
