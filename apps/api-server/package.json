{
  "name": "api-server",
  "version": "1.0.0",
  "private": false,
  "main": "dist/main.js",
  "scripts": {
    "dev": "rimraf tsconfig.tsbuildinfo && nest start --watch",
    "start": "nest start",
    "build": "rimraf dist && nest build && mkdir -p dist/migrations && cp -r ./migrations dist/migrations",
    "test": "jest",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit migrate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio:pg",
    "db:drop": "drizzle-kit drop:pg",
    "lint": "eslint . --ext .ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@agam-space/core": "workspace:*",
    "@agam-space/shared-types": "workspace:*",
    "@fastify/cookie": "7",
    "@fastify/static": "^6.0.0",
    "@napi-rs/blake-hash": "^1.3.0",
    "@nestjs/cache-manager": "^2.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/serve-static": "^3.0.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^5.1.0",
    "@node-rs/argon2": "^2.0.2",
    "cache-manager": "^5.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "drizzle-orm": "^0.29.0",
    "fastify": "^4.0.0",
    "helmet": "^7.1.0",
    "nestjs-zod": "^4.3.1",
    "pg": "^8.11.0",
    "postgres": "^3.4.0",
    "ulid": "^2.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^6.0.0",
    "drizzle-kit": "^0.20.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ]
}
